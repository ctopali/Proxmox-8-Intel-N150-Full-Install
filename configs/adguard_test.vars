# App-specific defaults for Adguard (adguard)
# Generated on 2026-07-13T15:14:49Z

var_os=debian
var_version=13
var_unprivileged=1
var_cpu=1
var_ram=512
var_disk=2
var_brg=vmbr0
var_net="$ADGUARD_IP"/24
